<%
    cart = @req.session['cart'] || {}
    if cart.empty?
        return redirect_to('/shop')
    end
    
    total = 0
    cart_items = cart.map do |id, qty|
        product = Product.find(id)
        next unless product
        total += product.price * qty
        { product: product, quantity: qty }
    end.compact
    user = AuthHelper.current_user(@req)
%>
<div class="max-w-7xl mx-auto px-6 py-12 animate__animated animate__fadeIn">
    <div class="mb-10">
        <h1 class="text-4xl font-black text-slate-900 mb-2 flex items-center gap-3">
            <i data-lucide="credit-card" class="w-10 h-10 text-indigo-600"></i> Pembayaran
        </h1>
        <div class="h-1.5 w-24 bg-indigo-600 rounded-full"></div>
    </div>

    <div class="lg:grid lg:grid-cols-12 lg:gap-x-12 items-start">
        <!-- Form Section -->
        <div class="lg:col-span-7 space-y-8">
            <div class="glass p-8 rounded-[40px] border border-white/60 shadow-xl">
                <h2 class="text-2xl font-black mb-8 flex items-center gap-3">
                    <i data-lucide="truck" class="w-6 h-6 text-indigo-600"></i> Informasi Pengiriman
                </h2>
                <form action="/checkout" method="POST" class="space-y-6">
                    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                        <div>
                            <label class="block text-sm font-bold text-slate-700 mb-2 ml-1 uppercase tracking-wider">Nama Lengkap</label>
                            <input type="text" name="customer_name" required value="<%= user ? user.name : '' %>"
                                placeholder="Masukkan nama Anda"
                                class="w-full glass bg-white/50 border border-white/60 rounded-2xl px-6 py-4 focus:ring-2 focus:ring-indigo-500 focus:bg-white outline-none transition shadow-sm">
                        </div>
                        <div>
                            <label class="block text-sm font-bold text-slate-700 mb-2 ml-1 uppercase tracking-wider">No. WhatsApp</label>
                            <input type="text" name="contact" required value="<%= user ? user.whatsapp : '' %>"
                                placeholder="081234567890"
                                class="w-full glass bg-white/50 border border-white/60 rounded-2xl px-6 py-4 focus:ring-2 focus:ring-indigo-500 focus:bg-white outline-none transition shadow-sm">
                        </div>
                        <div>
                            <label class="block text-sm font-bold text-slate-700 mb-2 ml-1 uppercase tracking-wider">Alamat Email</label>
                            <input type="email" name="customer_email" required value="<%= user ? user.email : '' %>"
                                placeholder="email@anda.com"
                                class="w-full glass bg-white/50 border border-white/60 rounded-2xl px-6 py-4 focus:ring-2 focus:ring-indigo-500 focus:bg-white outline-none transition shadow-sm">
                        </div>
                    </div>
                    <div>
                        <label class="block text-sm font-bold text-slate-700 mb-2 ml-1 uppercase tracking-wider">Alamat Lengkap</label>
                        <textarea name="address" required rows="3" 
                            placeholder="Jl. Merdeka No. 123, Jakarta Selatan..."
                            class="w-full glass bg-white/50 border border-white/60 rounded-2xl px-6 py-4 focus:ring-2 focus:ring-indigo-500 focus:bg-white outline-none transition shadow-sm"><%= user ? user.address : '' %></textarea>
                    </div>
                    
                    <h2 class="text-2xl font-black mt-12 mb-6 flex items-center gap-3 pt-6 border-t border-slate-200/50">
                        <i data-lucide="wallet" class="w-6 h-6 text-indigo-600"></i> Metode Pembayaran
                    </h2>
                    <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                        <label class="relative group cursor-pointer">
                            <input type="radio" name="payment" value="Manual" checked class="peer sr-only">
                            <div class="glass p-6 rounded-3xl border border-white/60 peer-checked:border-indigo-600 peer-checked:bg-indigo-50/30 transition-all flex items-center gap-4 hover:bg-white/80">
                                <div class="w-12 h-12 bg-white rounded-xl flex items-center justify-center text-indigo-600 shadow-sm">
                                    <i data-lucide="landmark" class="w-6 h-6"></i>
                                </div>
                                <div>
                                    <p class="font-bold text-slate-900">Transfer Manual</p>
                                    <p class="text-[10px] text-slate-400 font-bold uppercase tracking-widest">Bank BCA/Mandiri</p>
                                </div>
                                <div class="absolute top-4 right-4 text-indigo-600 opacity-0 peer-checked:opacity-100 transition-opacity">
                                    <i data-lucide="check-circle-2" class="w-5 h-5"></i>
                                </div>
                            </div>
                        </label>
                        
                        <label class="relative group cursor-pointer">
                            <input type="radio" name="payment" value="Gateway" class="peer sr-only">
                            <div class="glass p-6 rounded-3xl border border-white/60 peer-checked:border-indigo-600 peer-checked:bg-indigo-50/30 transition-all flex items-center gap-4 hover:bg-white/80">
                                <div class="w-12 h-12 bg-white rounded-xl flex items-center justify-center text-indigo-600 shadow-sm">
                                    <i data-lucide="zap" class="w-6 h-6"></i>
                                </div>
                                <div>
                                    <p class="font-bold text-slate-900">Auto Payment</p>
                                    <p class="text-[10px] text-slate-400 font-bold uppercase tracking-widest">Xendit Gateway</p>
                                </div>
                                <div class="absolute top-4 right-4 text-indigo-600 opacity-0 peer-checked:opacity-100 transition-opacity">
                                    <i data-lucide="check-circle-2" class="w-5 h-5"></i>
                                </div>
                            </div>
                        </label>
                    </div>

                    <div class="mt-12 pt-6">
                        <button type="submit" class="w-full bg-indigo-600 text-white py-6 rounded-[24px] font-black text-xl shadow-2xl shadow-indigo-100 hover:bg-slate-900 hover:shadow-none transition-all flex items-center justify-center gap-4">
                            Konfirmasi Pesanan <i data-lucide="check" class="w-7 h-7"></i>
                        </button>
                        <p class="text-center text-slate-400 text-xs mt-6 flex items-center justify-center gap-2">
                            <i data-lucide="lock" class="w-3 h-3"></i> Transaksi Anda terjamin aman dan terenkripsi
                        </p>
                    </div>
                </form>
            </div>
        </div>

        <!-- Summary Section -->
        <div class="lg:col-span-5 mt-12 lg:mt-0 sticky top-24">
            <div class="glass p-8 rounded-[40px] border border-white/60 shadow-xl relative overflow-hidden">
                <div class="absolute -top-10 -right-10 w-40 h-40 bg-indigo-600/5 blur-3xl rounded-full"></div>
                <h2 class="text-2xl font-black text-slate-900 mb-8 flex items-center gap-3">
                    <i data-lucide="package" class="w-6 h-6 text-indigo-600"></i> Detail Pesanan
                </h2>
                <ul class="space-y-4 mb-8">
                    <% cart_items.each do |item| %>
                        <li class="flex items-center gap-4 glass bg-white/20 p-3 rounded-2xl border border-white/40">
                            <div class="w-12 h-12 rounded-xl bg-slate-100 overflow-hidden flex-shrink-0">
                                <img src="<%= item[:product].image_url || 'https://via.placeholder.com/100' %>" class="w-full h-full object-cover">
                            </div>
                            <div class="flex-grow">
                                <p class="text-sm font-bold text-slate-800 line-clamp-1"><%= item[:product].name %></p>
                                <p class="text-[10px] text-slate-500 font-bold uppercase"><%= item[:quantity] %> Unit x <%= ViewHelper.format_rupiah(item[:product].price) %></p>
                            </div>
                            <span class="font-black text-slate-900"><%= ViewHelper.format_rupiah(item[:product].price * item[:quantity]) %></span>
                        </li>
                    <% end %>
                </ul>
                <div class="space-y-4 pt-6 border-t border-slate-200/50">
                    <div class="flex justify-between items-center">
                        <span class="text-slate-500 font-medium">Subtotal</span>
                        <span class="font-bold text-slate-900"><%= ViewHelper.format_rupiah(total) %></span>
                    </div>
                    <div class="flex justify-between items-center">
                        <span class="text-slate-500 font-medium">Pengiriman</span>
                        <span class="font-bold text-green-600">FREE</span>
                    </div>
                    <div class="flex justify-between items-center pt-4">
                        <span class="text-xl font-black text-slate-900">Total Akhir</span>
                        <span class="text-3xl font-black text-indigo-600"><%= ViewHelper.format_rupiah(total) %></span>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
