<div class="max-w-3xl mx-auto px-6 py-20 text-center animate__animated animate__fadeIn">
    <div class="relative inline-block mb-10">
        <div class="absolute inset-0 bg-green-400 blur-3xl opacity-20 animate-pulse"></div>
        <div class="glass w-24 h-24 rounded-full flex items-center justify-center border border-white/60 shadow-xl relative z-10 mx-auto">
            <i data-lucide="check-circle" class="w-14 h-14 text-green-500"></i>
        </div>
    </div>
    
    <h1 class="text-5xl font-black text-slate-900 mb-6 animate__animated animate__fadeInUp">
        <% if @order && @order.payment_method == 'Gateway' %>
            <%= @order.status == 'Paid' ? 'Pembayaran Berhasil!' : 'Menunggu Pembayaran' %>
        <% else %>
            Pesanan Berhasil!
        <% end %>
    </h1>
    <p class="text-xl text-slate-500 mb-12 animate__animated animate__fadeInUp animate__delay-1s">
        <% if @order && @order.payment_method == 'Gateway' %>
            <%= @order.status == 'Paid' ? 'Terima kasih telah berbelanja. Pembayaran Anda telah kami terima dan pesanan akan segera dikirim.' : 'Pesanan Anda telah kami terima. Silakan selesaikan pembayaran via Xendit.' %>
        <% else %>
            Terima kasih telah berbelanja di Antivoid Shop. Silakan lakukan pembayaran manual agar pesanan Anda dapat segera kami proses.
        <% end %>
    </p>
    
    <div class="glass p-8 rounded-[40px] border border-white/60 mb-12 animate__animated animate__fadeInUp animate__delay-1s">
        <h3 class="text-lg font-bold text-slate-800 mb-4 flex items-center justify-center gap-2">
            <i data-lucide="info" class="w-5 h-5 text-indigo-600"></i> Informasi Pesanan: <span class="text-indigo-600"><%= @order ? @order.status : 'Pending' %></span>
        </h3>
        <p class="text-slate-500 leading-relaxed mb-6">
            <% if @order && @order.payment_method == 'Gateway' %>
                <% if @order.status == 'Paid' %>
                    Pesanan Anda telah dibayar. Kami akan memproses pengiriman secepat mungkin.
                <% else %>
                    Pesanan Anda sedang menunggu konfirmasi pembayaran dari Xendit. Jika sudah membayar, status akan berubah otomatis.
                <% end %>
            <% else %>
                Silakan transfer ke rekening berikut:<br>
                <span class="font-bold text-slate-800">BCA: 1234567890 (A/N Antivoid Shop)</span><br>
                Konfirmasi pembayaran akan dikirimkan melalui email setelah tim kami melakukan verifikasi.
            <% end %>
        </p>
        <div class="h-px bg-slate-200/50 mx-10 mb-6"></div>
        <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
            <div class="flex items-center gap-2 text-sm font-bold text-slate-700">
                <i data-lucide="clock" class="w-4 h-4 text-orange-400"></i> Estimasi Pengiriman: 1-3 Hari Kerja
            </div>
        </div>
    </div>
    
    <div class="flex flex-col sm:flex-row items-center justify-center gap-4 animate__animated animate__fadeInUp animate__delay-2s">
        <a href="/" class="glass px-10 py-4 rounded-2xl font-bold text-lg hover:bg-white/80 transition text-slate-700 flex items-center gap-2">
            <i data-lucide="home" class="w-5 h-5"></i> Kembali ke Beranda
        </a>
        <a href="/shop" class="bg-indigo-600 text-white px-10 py-4 rounded-2xl font-bold text-lg shadow-xl shadow-indigo-100 hover:bg-slate-900 transition flex items-center gap-2">
            Belanja Lagi <i data-lucide="shopping-bag" class="w-5 h-5"></i>
        </a>
    </div>
</div>
